{
    "name": "Berkeley DataSci 207 Project",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "quarto.quarto"
            ]
        }
    },
    "remoteUser": "vscode",
    "postCreateCommand": "python3 -m pip install --user -r $(find /workspaces -name requirements.txt | head -n 1)"
}
